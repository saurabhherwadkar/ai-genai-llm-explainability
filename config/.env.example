# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# =============================================================================

# Application environment (development | production | testing)
LLMX_ENVIRONMENT=development

# OpenAI API credentials
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API credentials
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Ollama server URL (for local models)
OLLAMA_BASE_URL=http://localhost:11434

# HuggingFace access token (for gated models)
HUGGINGFACE_TOKEN=your-huggingface-token-here

# API security key (required in production)
LLMX_API_KEY=your-api-key-here

# Logging level override
LLMX_LOG_LEVEL=info
